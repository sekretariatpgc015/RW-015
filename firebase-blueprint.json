{
  "entities": {
    "Comment": {
      "title": "Comment",
      "description": "A comment left by a user on the website.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who created the comment."
        },
        "name": {
          "type": "string",
          "description": "The display name of the user."
        },
        "text": {
          "type": "string",
          "description": "The content of the comment."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date the comment was created (YYYY-MM-DD)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The ISO timestamp when the comment was created."
        },
        "replies": {
          "type": "array",
          "description": "A list of replies to this comment.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "userId": { "type": "string" },
              "name": { "type": "string" },
              "text": { "type": "string" },
              "date": { "type": "string" }
            },
            "required": ["id", "userId", "name", "text", "date"]
          }
        }
      },
      "required": ["userId", "name", "text", "date", "createdAt", "replies"]
    }
  },
  "firestore": {
    "/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Stores all comments."
    }
  }
}
